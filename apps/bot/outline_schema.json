{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Article Outline",
  "type": "object",
  "properties": {
    "h1": { "type": "string", "minLength": 10 },
    "meta_description": { "type": "string", "minLength": 100, "maxLength": 165 },
    "sections": {
      "type": "array",
      "minItems": 6,
      "maxItems": 8,
      "items": {
        "type": "object",
        "properties": {
          "h2": { "type": "string" },
          "h3s": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["h2", "h3s"]
      }
    },
    "faqs": { "type": "array", "minItems": 5, "items": { "type": "string" } },
    "comparison_columns": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["h1", "meta_description", "sections", "faqs"]
}
